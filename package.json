{
  "name": "paylink-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
  "apps/*",
  "packages/*"
],
  "scripts": {
    "dev": "pnpm --filter paylink-web dev",
    "build": "pnpm --filter paylink-web build",
    "server": "pnpm --filter paylink-server dev",
    "dev:all": "concurrently \"pnpm dev\" \"pnpm --filter paylink-server dev\"",
    "build:sdk": "pnpm --filter paylink-sdk build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
